# win-validator runtime environment — copy to winval.env, edit, and source it (or set these in the
# systemd unit / vmcompose env). Canonical code lives in this repo; data/secrets live OUTSIDE it.
#
#   code:    ~/win-validator            (this repo — github.com/wmetcalf/win-validator)
#   myatg:   ~/myatg                    (github.com/wmetcalf/myatg — compiled in-guest)
#   data:    ~/win-validator-data       (corpus / samples / keys / fakenet — NEVER committed)

# --- golden image (the disposable-worker base) -----------------------------------------------------
GOLDEN_MASTER=/var/lib/libvirt/images/winserver2025-core.qcow2   # baked `myatg --serve-http` golden
GOLDEN_BASE=/dev/shm/golden-base.qcow2                           # RAM base workers overlay off (COW)
AUTHENTICODE_GOLDEN_BASE=/dev/shm/golden-base.qcow2
AUTHENTICODE_SSH_KEY=/home/coz/.ssh/win_golden                  # key for the golden (build/admin)

# --- myatg source (staged + compiled in-guest by golden_build.py) ----------------------------------
MYATG_SRC=/home/coz/myatg                                        # a myatg checkout; default ../myatg

# --- warm pool / reuse ------------------------------------------------------------------------------
AUTHENTICODE_POOL_SIZE=2
AUTHENTICODE_JOBS_PER_RECYCLE=25                                 # 1 = snapshot-revert every job (max isolation)

# --- warm CRL cache + boot smoke test (optional; point at benign signed samples) -------------------
# AUTHENTICODE_WARM_DIR=/home/coz/win-validator-data/corpus
# AUTHENTICODE_SMOKE_SAMPLE=/home/coz/win-validator-data/samples/whoami.exe

# --- per-job overrides, forwarded per request (client-set, gated by the orchestrator allowlist) ----
# AUTHENTICODE_REV=online       # online|offline|none  ->  ?rev=      (verified: overrides server default)
# AUTHENTICODE_SCRIPTS=ps        # ps|native            ->  ?scripts=
#   AUTHENTICODE_GV is server-global (baked into the golden's serve startup); TIER is not a myatg param.

# --- worker egress (rooter): direct | openvpn | wireguard | tor | inetsim ---------------------------
# AUTHENTICODE_EXIT=openvpn
# AUTHENTICODE_EGRESS_PORTS=53,80,443
# AUTHENTICODE_BLOCK_INTERNAL=true
# AUTHENTICODE_IP_POOL=192.168.122.200-192.168.122.249            # pin+enforce a fixed worker IP

# --- job store (ingress <-> pool-manager boundary) -------------------------------------------------
# BLASTBOX_DATABASE_URL=postgresql://winval:CHANGEME@localhost:5432/winval
